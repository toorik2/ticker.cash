#!/usr/bin/env bash
# ticker — operator CLI for a ticker.cash node.
#
# Wraps systemctl (--user) + journalctl for lifecycle + log access, and reads
# the operator's own manifest + key(s) to surface slot identity and contract
# addresses without making the operator memorize them.
#
# Standard install puts this on the operator's PATH at ~/.local/bin/ticker
# (symlinked by install-payload.sh from ~/ticker.cash/daemon/scripts/ticker).

set -euo pipefail

UNIT=ticker-node.service
TICKER_HOME="${TICKER_HOME:-$HOME/ticker.cash}"
DOT_TICKER="$TICKER_HOME/daemon/.ticker"

die() { echo "ticker: $*" >&2; exit 1; }

require_unit() {
  if ! systemctl --user list-unit-files "$UNIT" --no-legend 2>/dev/null | grep -q "^$UNIT"; then
    die "no $UNIT installed. did you run the installer?"
  fi
}

cmd_status() {
  require_unit
  if [ -f "$DOT_TICKER/manifest.json" ] && command -v node >/dev/null 2>&1; then
    node -e '
      const fs = require("fs");
      const m = JSON.parse(fs.readFileSync(process.env.DOT_TICKER + "/manifest.json", "utf8"));
      console.log("ticker.cash node");
      console.log("  network:  " + m.network);
      console.log("  oracle:   " + m.contracts.oracle.address);
      console.log("  slot:     " + m.contracts.slot.address);
      console.log("  fulcrum:  " + m.electrum.host + ":" + m.electrum.port + (m.electrum.tls ? " (tls)" : ""));
    ' 2>/dev/null || true
    echo
  fi
  systemctl --user status "$UNIT" --no-pager --lines 0 || true
  echo
  echo "last 12 log lines:"
  journalctl --user -u "$UNIT" --no-pager -n 12 -o cat 2>/dev/null || true
}

cmd_start()   { require_unit; systemctl --user start   "$UNIT"; echo "started";   }
cmd_stop()    { require_unit; systemctl --user stop    "$UNIT"; echo "stopped";   }
cmd_restart() { require_unit; systemctl --user restart "$UNIT"; echo "restarted"; }

cmd_logs() {
  require_unit
  local follow=0
  for arg in "$@"; do
    case "$arg" in
      -f|--follow) follow=1 ;;
      *) die "unknown logs flag: $arg (use -f / --follow)" ;;
    esac
  done
  if [ "$follow" -eq 1 ]; then
    journalctl --user -u "$UNIT" -f -o cat
  else
    journalctl --user -u "$UNIT" --no-pager -n 100 -o cat
  fi
}

cmd_upgrade() {
  require_unit
  [ -d "$TICKER_HOME/.git" ] || die "no git repo at $TICKER_HOME"
  echo "[1/3] fetching latest from origin/main..."
  git -C "$TICKER_HOME" fetch --quiet origin main
  local from to
  from=$(git -C "$TICKER_HOME" rev-parse --short HEAD)
  to=$(git -C "$TICKER_HOME" rev-parse --short origin/main)
  if [ "$from" = "$to" ]; then
    echo "       already at $to ✓"
    return 0
  fi
  echo "       $from → $to"
  git -C "$TICKER_HOME" reset --hard --quiet origin/main
  echo "[2/3] npm install..."
  (cd "$TICKER_HOME/daemon" && npm install --silent --no-audit --no-fund)
  echo "[3/3] restarting $UNIT..."
  systemctl --user restart "$UNIT"
  sleep 2
  if systemctl --user is-active --quiet "$UNIT"; then
    echo "       active ✓"
  else
    echo "       FAILED to come up; check: ticker logs" >&2
    exit 1
  fi
}

cmd_help() {
  cat <<EOF
ticker — operator CLI for a ticker.cash node

usage: ticker <command> [args]

commands:
  status              show service state + recent log lines
  start               start the daemon (systemctl --user start)
  stop                stop  the daemon
  restart             restart the daemon
  logs [-f]           show last 100 log lines (-f to follow)
  upgrade             git pull origin/main, npm install, restart
  help                show this message

paths:
  TICKER_HOME=$TICKER_HOME
  .ticker dir=$DOT_TICKER
  unit=$UNIT (systemd --user)

raw commands you can run directly:
  systemctl --user status $UNIT
  journalctl --user -fu $UNIT
EOF
}

export DOT_TICKER

main() {
  local cmd="${1:-status}"
  if [ $# -gt 0 ]; then shift || true; fi
  case "$cmd" in
    status)         cmd_status ;;
    start)          cmd_start ;;
    stop)           cmd_stop ;;
    restart)        cmd_restart ;;
    logs|log|tail)  cmd_logs "$@" ;;
    upgrade|update) cmd_upgrade ;;
    help|-h|--help) cmd_help ;;
    *) die "unknown command: $cmd (run 'ticker help')" ;;
  esac
}

main "$@"
